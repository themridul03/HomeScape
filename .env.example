# ==========================================
# HomeScape Frontend Environment Variables
# ==========================================
# Copy this file to .env and update values for your environment.

# Backend API base URL (without trailing /api)
# Local development:
VITE_API_BASE_URL=http://localhost:4000
# Production example:
# VITE_API_BASE_URL=https://real-estate-website-backend-zfu7.onrender.com

# Feature flag for AI Property Hub navigation/page
VITE_ENABLE_AI_HUB=true